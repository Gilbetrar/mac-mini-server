# Caddyfile — Mac Mini reverse proxy
# Managed by: mac-mini-server repo
#
# Caddy listens on :80, cloudflared routes tunnel traffic here.
# Each service gets a host-matched block.
{
	log {
		output file /Users/ben/services/data/caddy/access.log {
			roll_size 10mb
			roll_keep 5
		}
	}
}

# OpenClaw gateway — control UI, API, and webhooks
:80 {
	@openclaw host openclaw.bjblabs.com
	handle @openclaw {
		# Gmail Pub/Sub webhook — routed to gog watch serve on port 8788
		@gmail_webhook path /gmail-pubsub*
		handle @gmail_webhook {
			reverse_proxy localhost:8788
		}

		# Everything else — gateway UI and API
		reverse_proxy localhost:18789
	}

	# Anki Renderer demo — static files + deploy webhook
	@anki_renderer host anki-renderer.bjblabs.com
	handle @anki_renderer {
		# Deploy webhook — receives build artifacts from GitHub Actions
		@deploy path /_deploy
		handle @deploy {
			reverse_proxy localhost:9001
		}

		# Static demo site
		root * /Users/ben/services/anki-renderer/dist
		file_server
	}

	# Legal Podcast — service API + static data files + admin UI
	@legalpodcast host legalpodcast.bjblabs.com
	handle @legalpodcast {
		# Webhook and API routes — proxy to service container
		@service_routes {
			path /webhooks/*
			path /api/*
			path /health
		}
		handle @service_routes {
			reverse_proxy localhost:9002
		}

		# Static data files — served directly by Caddy from the data volume
		@data_files {
			path /audio/*
			path /redlines/*
			path /images/*
			path /feed.xml
		}
		handle @data_files {
			root * /Users/ben/services/legal-podcast/data
			file_server
		}

		# Admin UI — vanilla HTML/CSS/JS
		handle {
			root * /Users/ben/services/legal-podcast/admin-ui
			try_files {path} /index.html
			file_server
		}
	}

	# NocoDB — self-hosted database
	@nocodb host data.bjblabs.com
	handle @nocodb {
		reverse_proxy localhost:8080
	}

	# Default — no matching service
	handle {
		respond "Mac Mini server is running." 200
	}
}
