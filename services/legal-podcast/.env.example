# Legal Podcast Service — Environment Variables
# Copy to .env and fill in values.
# Secrets can be pulled from AWS SSM before the stack is deleted:
#   aws ssm get-parameter --name "/legal-podcast/openai-api-key" --with-decryption --query "Parameter.Value" --output text

# --- Required ---

# Webhook secret — must match the Cloudflare Email Worker's X-Webhook-Secret header
# Value stored on Mac Mini at ~/services/config/alerts/email-webhook.env
WEBHOOK_SECRET=

# Admin console password
ADMIN_PASSWORD=

# JWT signing secret (generate with: openssl rand -hex 32)
JWT_SECRET=

# --- TTS Providers (at least one required) ---

OPENAI_API_KEY=
REPLICATE_API_TOKEN=

# --- Email Notifications ---

# Resend API key for sending notification emails
RESEND_API_KEY=

# From address for notifications (must be verified in Resend)
NOTIFICATION_FROM_EMAIL=podcast@bjblabs.com

# Admin alert email for billing errors
ADMIN_ALERT_EMAIL=ben.bateman.email@gmail.com

# --- URLs ---

# Public feed URL
FEED_URL=https://legalpodcast.bjblabs.com/feed.xml

# Base URL for audio files (Caddy serves these from the data volume)
AUDIO_BASE_URL=https://legalpodcast.bjblabs.com

# Base URL for redline documents
REDLINES_BASE_URL=https://legalpodcast.bjblabs.com

# Base URL for cover images
IMAGES_BASE_URL=https://legalpodcast.bjblabs.com

# Default inbound email shown in admin UI
DEFAULT_INBOUND_EMAIL=podcast@bjblabs.com
